# PostgreSQL — local: postgresql://user:password@localhost:5432/webcore
DATABASE_URL="postgresql://user:password@host:port/database"

# OpenAI — used for embeddings (text-embedding-3-small) + chat (gpt-4o-mini)
OPENAI_API_KEY="sk-..."

# Pinecone — create a serverless index with dimension=1536, metric=cosine
PINECONE_API_KEY="..."
PINECONE_INDEX="..."

# Sanity
# 1. Run `npx sanity init --bare` to create a project and get your Project ID.
# 2. Create a read token at https://sanity.io/manage → API → Tokens → Add token (Viewer role).

# Public — safe to expose to browser (Studio needs them client-side)
NEXT_PUBLIC_SANITY_PROJECT_ID="..."
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-01-01"

# Private — server-side ONLY. Never reference in any "use client" file.
SANITY_API_READ_TOKEN="..."

# Write token — Editor/Admin role. Used ONLY by the seed script (scripts/seed-sanity.ts).
# Create at: https://sanity.io/manage → API → Tokens → Add token (Editor role)
SANITY_API_WRITE_TOKEN="..."

# Optional: webhook secret for on-demand revalidation (/api/revalidate)
SANITY_REVALIDATE_SECRET=""
