generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  sessionId String?
  name      String
  email     String
  company   String
  createdAt DateTime @default(now())

  @@index([email])
  @@index([sessionId])
}

model ChatLog {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model PageContent {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([slug])
}
